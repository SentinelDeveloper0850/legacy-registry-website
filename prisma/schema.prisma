generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Cemetery {
  id           String  @id @default(cuid())
  name         String
  municipality String?
  province     String?
  address      String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  blocks       CemeteryBlock[]
  graveRecords GraveRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([municipality])
  @@index([province])
}

model CemeteryBlock {
  id String @id @default(cuid())

  cemeteryId String
  cemetery   Cemetery @relation(fields: [cemeteryId], references: [id], onDelete: Cascade)

  name        String
  description String?
  capacity    Int?

  graveRecords GraveRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cemeteryId, name])
  @@index([cemeteryId])
  @@index([name])
}

model GraveRecord {
  id String @id @default(cuid())

  cemeteryId String
  cemetery   Cemetery @relation(fields: [cemeteryId], references: [id], onDelete: Cascade)

  cemeteryBlockId String?
  cemeteryBlock   CemeteryBlock? @relation(fields: [cemeteryBlockId], references: [id], onDelete: SetNull)

  firstNames String
  lastName   String
  fullName   String

  dateOfBirth  DateTime?
  dateOfDeath  DateTime?
  dateOfBurial DateTime?

  burialType BurialType @default(BURIAL)

  rowNumber   String?
  graveNumber String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firstNames])
  @@index([lastName])
  @@index([fullName])
  @@index([cemeteryId])
  @@index([cemeteryBlockId])
  @@index([dateOfBurial])
  @@index([burialType])
}

enum BurialType {
  BURIAL
  CREMATION
  ASH_INTERMENT
  MEMORIAL_ONLY
}
