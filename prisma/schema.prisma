generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Undertaker {
  id String @id @default(cuid())

  name         String
  tradingName  String?
  branchName   String?
  contactEmail String?
  contactPhone String?

  users                  User[]
  mortuaryRegisterEntries MortuaryRegisterEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([tradingName])
}

model User {
  id String @id @default(cuid())

  undertakerId String
  undertaker   Undertaker @relation(fields: [undertakerId], references: [id], onDelete: Cascade)

  name     String
  email    String @unique
  role     UserRole @default(UNDERTAKER_USER)
  isActive Boolean  @default(true)

  mortuaryRegisterEntriesCreated MortuaryRegisterEntry[] @relation("MortuaryRegisterEntryCreatedBy")
  mortuaryRegisterEntriesUpdated MortuaryRegisterEntry[] @relation("MortuaryRegisterEntryUpdatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([undertakerId])
  @@index([role])
}

model Cemetery {
  id           String  @id @default(cuid())
  name         String
  municipality String?
  province     String?
  address      String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  blocks       CemeteryBlock[]
  graveRecords GraveRecord[]
  mortuaryRegisterEntries MortuaryRegisterEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([municipality])
  @@index([province])
}

model CemeteryBlock {
  id String @id @default(cuid())

  cemeteryId String
  cemetery   Cemetery @relation(fields: [cemeteryId], references: [id], onDelete: Cascade)

  name        String
  description String?
  capacity    Int?

  graveRecords GraveRecord[]
  mortuaryRegisterEntries MortuaryRegisterEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cemeteryId, name])
  @@index([cemeteryId])
  @@index([name])
}

model GraveRecord {
  id String @id @default(cuid())

  cemeteryId String
  cemetery   Cemetery @relation(fields: [cemeteryId], references: [id], onDelete: Cascade)

  cemeteryBlockId String?
  cemeteryBlock   CemeteryBlock? @relation(fields: [cemeteryBlockId], references: [id], onDelete: SetNull)

  firstNames String
  lastName   String
  fullName   String

  dateOfBirth  DateTime?
  dateOfDeath  DateTime?
  dateOfBurial DateTime?

  burialType BurialType @default(BURIAL)

  rowNumber   String?
  graveNumber String?

  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([firstNames])
  @@index([lastName])
  @@index([fullName])
  @@index([cemeteryId])
  @@index([cemeteryBlockId])
  @@index([dateOfBurial])
  @@index([burialType])
}

model MortuaryRegisterEntry {
  id String @id @default(cuid())

  undertakerId String
  undertaker   Undertaker @relation(fields: [undertakerId], references: [id], onDelete: Cascade)

  createdByUserId String
  createdByUser   User @relation("MortuaryRegisterEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  updatedByUserId String?
  updatedByUser   User? @relation("MortuaryRegisterEntryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  bodyNumber String

  firstNames String
  lastName   String
  fullName   String
  idNumber   String?

  dateReceivedAtMortuary DateTime?
  dateReleasedFromMortuary DateTime?
  timeReleasedFromMortuary String?

  driverName String?
  coffinType String?

  cemeteryId String?
  cemetery   Cemetery? @relation(fields: [cemeteryId], references: [id], onDelete: SetNull)

  cemeteryBlockId String?
  cemeteryBlock   CemeteryBlock? @relation(fields: [cemeteryBlockId], references: [id], onDelete: SetNull)

  graveNumber String?

  publishToRegistry Boolean @default(false)
  publishedAt       DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([undertakerId, bodyNumber])
  @@index([undertakerId])
  @@index([createdByUserId])
  @@index([cemeteryId])
  @@index([cemeteryBlockId])
  @@index([fullName])
  @@index([idNumber])
  @@index([publishToRegistry])
}

enum UserRole {
  UNDERTAKER_ADMIN
  UNDERTAKER_USER
  REGISTRY_ADMIN
}

enum BurialType {
  BURIAL
  CREMATION
  ASH_INTERMENT
  MEMORIAL_ONLY
}
